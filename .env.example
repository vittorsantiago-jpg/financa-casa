# =============================================================================
# FINANÇA DA CASA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA commite o .env.local no Git.
# =============================================================================

# Supabase — encontre em: Supabase > Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_publica_aqui

# A Service Role Key NÃO deve ir para o cliente.
# Use-a apenas em Server Actions / Route Handlers se necessário.
# SUPABASE_SERVICE_ROLE_KEY=nunca_exponha_esta_chave_no_frontend
